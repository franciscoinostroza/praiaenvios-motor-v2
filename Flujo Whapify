Script:
const texto = `{{respuesta_ia}}`;
const lineas = texto.split('\n');
let jsonString = '';
for (let i = 0; i < lineas.length; i++) {
  if (lineas[i].includes('DATOS')) {
    const partes = lineas[i].split('DATOS');
    if (partes.length > 1) {
      jsonString = partes[1].trim();
    }
    break;
  }
}
if (!jsonString) {
  for (let i = 0; i < lineas.length - 1; i++) {
    if (lineas[i].includes('DATOS') && lineas[i + 1]) {
      jsonString = lineas[i + 1].trim();
      break;
    }
  }
}
const match = jsonString.match(/\{[\s\S]*\}/);
if (match) jsonString = match[0];
return jsonString;

