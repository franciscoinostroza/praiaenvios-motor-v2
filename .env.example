# PostgreSQL (Railway provee DATABASE_URL automáticamente)
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Puerto del servidor
PORT=3000

# UPS Client Credentials — Cuenta 1 (internacional, fuera de Venezuela)
UPS_CUENTA_1_ID=
UPS_CUENTA_1_SECRET=
UPS_CUENTA_1_ACCOUNT=EW0793

# UPS Client Credentials — Cuenta 2 (Venezuela)
UPS_CUENTA_2_ID=
UPS_CUENTA_2_SECRET=
UPS_CUENTA_2_ACCOUNT=B68686

# UPS origen (Brasil)
UPS_ORIGEN_PAIS=BR
UPS_ORIGEN_CIUDAD=Curitiba
UPS_ORIGEN_ESTADO=PR
UPS_ORIGEN_ZIP=80000-000

# Admin panel password
ADMIN_PASSWORD=admin123

# Tasa de dolar por defecto (si no está en formulas)
DEFAULT_TASA_DOLAR=4.60

# OpenAI API key para clasificación de categorías con IA
OPENAI_API_KEY=sk-tu-api-key-aqui

# Formato completo (Praia + UPS combinados). true/false
# Cuando está en false, el sistema funciona como antes (legacy)
FORMATO_COMPLETO=true
